# PostgreSQL
POSTGRES_USER=stockai
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=stockai_db
DATABASE_URL=postgresql+asyncpg://stockai:your_password_here@postgres:5432/stockai_db

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# vnstock (Free registration at https://vnstocks.com/login)
VNSTOCK_API_KEY=your_vnstock_api_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Configuration directory (mounted read-only in containers)
CONFIG_DIR=/app/config

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
